<?xml version="1.0" encoding="utf-8"?>
<!--
  Belt-and-braces: allowBackup is already false in the manifest, so these rules
  only kick in if someone flips the flag. Exclude everything — tokens, pinned
  cert fingerprints, stream config — from both cloud backup and device-to-device
  transfer.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
